# AISStream API Key (obtain from https://aisstream.io/)
AISSTREAM_API_KEY=your_api_key_here

PORT=3000
NODE_ENV=production

# Bounding box coordinates configuration (e.g. Singapore Strait)
# Format is a JSON array of bounding boxes: [[[lat_min, lon_min], [lat_max, lon_max]]]
AISSTREAM_BOUNDING_BOXES=[[[1.15, 103.6], [1.45, 104.1]]]

# Threshold in seconds of no messages before flagging a Silent Failure
SILENCE_TIMEOUT_SECONDS=60

# API rate limiting and response caching
API_RATE_LIMIT_RPM=60
API_CACHE_TTL_SECONDS=15
