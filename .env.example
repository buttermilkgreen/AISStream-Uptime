# Secret API Key from aisstream.io (Required)
AISSTREAM_API_KEY=your_api_key_here

# WebSocket stream URL. Change to ws://localhost:8088/v0/stream to connect to local simulator
AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream

# Port on which the HTTP server and dashboard will run
PORT=3000

# Set to true or DEV to enable developer logs and testing simulator HUD
DEV=false
NODE_ENV=production

# JSON array defining coordinate bounding boxes to subscribe to (defaults to Singapore Strait)
# Format: [[[latitude_min, longitude_min], [latitude_max, longitude_max]]]
AISSTREAM_BOUNDING_BOXES=[[[1.15, 103.6], [1.45, 104.1]]]

# Seconds of data silence before declaring a Silent Failure
SILENCE_TIMEOUT_SECONDS=15

# Seconds a stream can remain in Silent Failure before being marked as Down
SILENCE_TO_DOWN_TIMEOUT_SECONDS=3600

# Max API requests permitted per minute per IP address
API_RATE_LIMIT_RPM=60

# Lifespan in seconds of cached JSON responses for status/incidents requests
API_CACHE_TTL_SECONDS=15

# Cryptographically secure random token to authorize manual incident updates/edits
ADMIN_API_KEY=your_admin_api_key_here

# Retention period in days for telemetry check-ins
TELEMETRY_RETENTION_DAYS=90

# Retention period in days for API request logs
API_LOGS_RETENTION_DAYS=30
